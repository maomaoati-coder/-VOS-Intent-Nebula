#include <WiFi.h>
#include <WebSocketsServer.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

const char* ssid = "你的WiFi名称";
const char* password = "你的WiFi密码";

Adafruit_SSD1306 display(128, 64, &Wire, -1);
WebSocketsServer webSocket = WebSocketsServer(81);
WiFiServer server(80);

unsigned long gazeStart = 0;
int conversionCount = 0;

String getHTML() {
  String html = "<html><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1'>";
  html += "<style>body{margin:0;background:#000;color:#0ff;font-family:monospace;}";
  html += "video{width:100vw;height:100vh;object-fit:cover;opacity:0.6;}";
  html += "#ui{position:fixed;top:20px;left:20px;z-index:100;background:rgba(0,0,0,0.5);padding:10px;}</style></head><body>";
  html += "<div id='ui'>GAZE: <span id='g'>0</span>s</div>";
  html += "<video id='v' autoplay muted loop playsinline><source src='https://vjs.zencdn.net/v/oceans.mp4'></video>";
  html += "<script>var ws=new WebSocket('ws://'+location.hostname+':81/');";
  html += "ws.onmessage=(e)=>{if(e.data.startsWith('G:')){document.getElementById('g').innerHTML=e.data.split(':')[1];}};";
  html += "</script></body></html>";
  return html;
}

void setup() {
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay();
  display.setTextColor(WHITE);
  display.setCursor(0,20);
  display.println("VOS 1.0 ONLINE");
  display.display();

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); }
  
  server.begin();
  webSocket.begin();
  gazeStart = millis();
}

void loop() {
  webSocket.loop();
  WiFiClient client = server.available();
  if (client) {
    client.print("HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n");
    client.print(getHTML());
    client.stop();
  }

  unsigned long currentGaze = (millis() - gazeStart) / 1000;
  static unsigned long lastSync = 0;
  if (millis() - lastSync > 1000) {
    webSocket.broadcastTXT("G:" + String(currentGaze));
    display.clearDisplay();
    display.setCursor(0,0);
    display.print("GAZE: "); display.print(currentGaze); display.println("s");
    display.print("CONV: "); display.println(conversionCount);
    display.display();
    lastSync = millis();
  }

  if (touchRead(4) < 40) {
    if (currentGaze >= 5) conversionCount++;
    gazeStart = millis();
    delay(500);
  }
}
