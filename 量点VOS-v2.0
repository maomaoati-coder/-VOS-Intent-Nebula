#include <WiFi.h>
#include <WebSocketsServer.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

const char* ssid = "你的WiFi名称";
const char* password = "你的WiFi密码";

Adafruit_SSD1306 display(128, 64, &Wire, -1);
WebSocketsServer webSocket = WebSocketsServer(81);
WiFiServer server(80);

unsigned long gazeStart = 0;

void sendPage(WiFiClient& client) {
  client.print("HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n");
  client.print("<html><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1'>");
  client.print("<style>body{margin:0;background:#000;color:#0ff;font-family:monospace;overflow:hidden;transition:background 2s;}");
  client.print("video{width:100vw;height:100vh;object-fit:cover;position:absolute;top:0;left:0;opacity:0;transition:0.3s;}");
  client.print(".active{opacity:1;} #ui{position:fixed;top:20px;left:20px;z-index:100;background:rgba(0,0,0,0.6);padding:10px;border:1px solid #0ff;}");
  client.print("#mask{position:fixed;top:0;left:0;width:100%;height:100%;background:#000;z-index:999;display:flex;justify-content:center;align-items:center;cursor:pointer;}</style></head><body>");
  client.print("<div id='mask' onclick='initVOS()'>[ CLICK TO WAKE PORTAL ]</div>");
  client.print("<div id='ui'>HEAT: <span id='h'>0</span>%</div>");
  client.print("<video id='v0' class='active' muted loop playsinline><source src='https://vjs.zencdn.net/v/oceans.mp4'></video>");
  client.print("<video id='v1' muted loop playsinline><source src='https://www.w3schools.com/html/mov_bbb.mp4'></video>");
  client.print("<video id='v2' muted loop playsinline><source src='https://media.w3.org/2010/05/sintel/trailer.mp4'></video>");
  client.print("<script>var vids=[document.getElementById('v0'),document.getElementById('v1'),document.getElementById('v2')];var idx=0;var ws;");
  client.print("function initVOS(){document.getElementById('mask').style.display='none';vids.forEach(v=>v.play());connect();}");
  client.print("function connect(){ws=new WebSocket('ws://'+location.hostname+':81/');");
  client.print("ws.onmessage=(e)=>{if(e.data=='JUMP'){vids[idx].classList.remove('active');idx=(idx+1)%3;vids[idx].classList.add('active');document.body.style.background='#000';}");
  client.print("else if(e.data.startsWith('H:')){let h=e.data.split(':')[1];document.getElementById('h').innerHTML=h;document.body.style.background='rgba('+h+',0,0,0.5)';}};}</script></body></html>");
}

void setup() {
  Wire.begin(21, 22);
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(100); }
  server.begin();
  webSocket.begin();
  gazeStart = millis();
}

void loop() {
  webSocket.loop();
  WiFiClient client = server.available();
  if (client) { sendPage(client); client.stop(); }

  int heat = constrain((millis() - gazeStart) / 100, 0, 100);
  static unsigned long lastSync = 0;
  if (millis() - lastSync > 200) {
    webSocket.broadcastTXT("H:" + String(heat));
    display.clearDisplay();
    display.setCursor(0,0);
    display.println("PORTAL HEAT:");
    display.drawRect(0, 30, 128, 10, WHITE);
    display.fillRect(0, 30, map(heat, 0, 100, 0, 128), 10, WHITE);
    display.display();
    lastSync = millis();
  }

  if (touchRead(4) < 35) {
    webSocket.broadcastTXT("JUMP");
    gazeStart = millis();
    delay(500);
  }
}
